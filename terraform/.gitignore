# Local .terraform directories
.terraform/

# State files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Variable files with real values — NEVER commit
terraform.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json

# Saved plan files
tfplan
*.tfplan

# Note: .terraform.lock.hcl IS intentionally committed (pins provider versions)
